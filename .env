NODE_ENV=development
PORT=4000

# Next.js frontend: frontend/.env.local — use the same host/port as the API (Next.js usually runs on 3000)
NEXT_PUBLIC_API_URL=http://localhost:4000

DATABASE_URL=postgres://postgres:postgres@localhost:5432/program
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=dev-access-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-in-production
REFRESH_TOKEN_PEPPER=dev-refresh-token-pepper-change-in-production

BCRYPT_ROUNDS=12

